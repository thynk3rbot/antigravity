{
  "$schema": "magic-plugin-v1",
  "name": "viai-site",
  "display_name": "viai.club Website",
  "description": "Standard customer website for viai.club including product showcase and RAG search",
  "version": "1.0.0",
  "author": "spw1",

  "run": {
    "cmd": "python server.py",
    "cwd": ".",
    "env_file": ".env",
    "language": "python",
    "requirements": "requirements.txt"
  },

  "port": 8010,
  "health": {
    "endpoint": "/health",
    "interval_s": 60,
    "timeout_s": 5,
    "retries": 2
  },

  "infrastructure": {
    "requires": ["mqtt"],
    "docker_compose": null
  },

  "auto_start": false,
  "restart_policy": "on-failure",

  "menu": {
    "group": "Customers",
    "icon": "🐙",
    "url": "http://localhost:8010",
    "actions": [
      {"label": "Open viai.club", "type": "url", "value": "http://localhost:8010"},
      {"label": "Search Docs", "type": "url", "value": "http://localhost:8010/docs.html"},
      {"label": "View Logs", "type": "action", "value": "logs"}
    ]
  }
}
