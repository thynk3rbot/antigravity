# Local API Endpoint for Open WebUI and other agents to reach Ollama on the Windows Host
LOCAL_API=http://host.docker.internal:11434

# Open WebUI specific settings
WEBUI_PORT=3000

# Sandbox Data Mount
SANDBOX_DIR=./agent_sandbox
