{
  "name": "@metaclaw/memory",
  "version": "0.1.0",
  "description": "MetaClaw Memory — self-evolving local memory for OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["openclaw", "plugin", "memory", "local", "metaclaw"],
  "license": "MIT",
  "dependencies": {
    "@sinclair/typebox": "^0.32.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "openclaw": { "optional": true }
  },
  "engines": {
    "node": ">=18"
  },
  "files": ["dist/", "openclaw.plugin.json", "sidecar/"]
}
