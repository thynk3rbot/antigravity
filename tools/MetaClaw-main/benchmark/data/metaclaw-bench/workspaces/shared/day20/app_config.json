{
  "app_name": "metaclaw_platform",
  "version": "2.4.1",
  "environment": "production",
  "feature_flags": {
    "new_dashboard": false,
    "advanced_analytics": true,
    "beta_api_v3": false,
    "dark_mode": true
  },
  "database": {
    "pool_size": 50,
    "timeout_ms": 5000,
    "retry_attempts": 3
  },
  "cache": {
    "enabled": true,
    "ttl_seconds": 300,
    "max_entries": 10000
  },
  "logging": {
    "level": "info",
    "format": "json"
  }
}
