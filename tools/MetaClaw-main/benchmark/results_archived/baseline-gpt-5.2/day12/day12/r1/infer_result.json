            "name": "exec",
            "arguments": {
              "command": "python - <<'PY'\nimport json,math\nfrom pathlib import Path\np=Path('day12/monthly_api_stats_raw.json')\nraw=json.loads(p.read_text())\nendpoints=raw['endpoints']\n# compute overall\ntotal_calls=sum(e['calls'] for e in endpoints)\nweighted_avg_ms=sum(e['calls']*e['avg_response_ms'] for e in endpoints)/total_calls\nestimated_errors=sum(e['calls']*e['error_rate'] for e in endpoints)\noverall_error_rate=estimated_errors/total_calls\n# build endpoint summaries\nsumm=[]\nfor e in endpoints:\n    calls=e['calls']\n    share=calls/total_calls\n    est_err=calls*e['error_rate']\n    summ.append({\n        'path':e['path'],\n        'calls':calls,\n        'call_share':share,\n        'avg_response_ms':e['avg_response_ms'],\n        'error_rate':e['error_rate'],\n        'estimated_errors':est_err,\n        'estimated_successes':calls-est_err,\n    })\n# sort by calls desc\nsumm.sort(key=lambda x:x['calls'],reverse=True)\n# overall\nreport={\n  'schema_version':'1.0',\n  'report_name':'normalized_monthly_api_statistics',\n  'source_file':str(p),\n  'report_period':{\n     'label':raw.get('report_period'),\n     'start_date':raw.get('period_start'),\n     'end_date':raw.get('period_end'),\n  },\n  'overall_metrics':{\n     'total_calls':total_calls,\n     'weighted_avg_response_ms':weighted_avg_ms,\n     'overall_error_rate':overall_error_rate,\n     'estimated_total_errors':estimated_errors,\n     'estimated_total_successes':total_calls-estimated_errors,\n     'endpoint_count':len(endpoints),\n  },\n  'endpoint_summary':summ,\n  'rankings':{\n     'by_calls_top3':[{'path':x['path'],'calls':x['calls']} for x in summ[:3]],\n     'by_avg_response_ms_slowest_top3':[{'path':x['path'],'avg_response_ms':x['avg_response_ms']} for x in sorted(summ,key=lambda x:x['avg_response_ms'],reverse=True)[:3]],\n     'by_error_rate_top3':[{'path':x['path'],'error_rate':x['error_rate']} for x in sorted(summ,key=lambda x:x['error_rate'],reverse=True)[:3]],\n  },\n  'notes':[\n     'weighted_avg_response_ms is weighted by call volume.',\n     'estimated_* values are derived from calls * error_rate; they may be fractional.',\n  ]\n}\n# round floats reasonably\n\ndef round_floats(o):\n    if isinstance(o,float):\n        return round(o,6)\n    if isinstance(o,list):\n        return [round_floats(x) for x in o]\n    if isinstance(o,dict):\n        return {k:round_floats(v) for k,v in o.items()}\n    return o\nreport=round_floats(report)\nout=Path('day12/monthly_api_stats_normalized_report.json')\nout.write_text(json.dumps(report,indent=2,sort_keys=False)+\"\\n\")\nprint('wrote',out)\nprint(json.dumps(report['overall_metrics'],indent=2))\nPY"
