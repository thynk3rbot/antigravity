            "arguments": {
              "command": "python - <<'PY'\nimport json\nfrom datetime import date\nfrom pathlib import Path\nraw=json.loads(Path('day12/user_sessions_raw.json').read_text())\nsessions=raw['sessions']\n# thresholds\nHIGH_MIN=150\nMED_MIN=50\n\ndef level(cnt):\n    if cnt>=HIGH_MIN:\n        return 'high'\n    if cnt>=MED_MIN:\n        return 'medium'\n    return 'low'\n# period days (March 2026)\nstart=date(2026,3,1)\nend=date(2026,3,31)\ndays=(end-start).days+1\n# per-user enrich\nusers=[]\nfor s in sessions:\n    cnt=s['session_count']\n    dur=s['avg_duration_min']\n    users.append({\n        'user_id':s['user_id'],\n        'session_count':cnt,\n        'avg_duration_min':dur,\n        'estimated_total_minutes':cnt*dur,\n        'last_active':s['last_active'],\n        'activity_level':level(cnt),\n        'sessions_per_day':round(cnt/days,6),\n    })\n# overall\ntotal_users=raw.get('total_users',len(users))\ntotal_sessions=raw.get('total_sessions',sum(u['session_count'] for u in users))\nlevels={'high':0,'medium':0,'low':0}\nfor u in users:\n    levels[u['activity_level']]+=1\n# define overall activity rate as sessions per user per day\nactivity_rate= total_sessions/(total_users*days)\ncontent={\n  'schema_version':'1.0',\n  'report_name':'user_activity_analysis',\n  'source_file':'day12/user_sessions_raw.json',\n  'period':{\n     'label':raw.get('period'),\n     'start_date':str(start),\n     'end_date':str(end),\n     'days':days,\n  },\n  'classification_rules':{\n     'metric':'session_count',\n     'high':{'>=':HIGH_MIN},\n     'medium':{'range_inclusive':[MED_MIN,HIGH_MIN-1]},\n     'low':{'<':MED_MIN},\n  },\n  'overall_metrics':{\n     'total_users':total_users,\n     'total_sessions':total_sessions,\n     'avg_sessions_per_user':round(total_sessions/total_users,6),\n     'overall_activity_rate_sessions_per_user_per_day':round(activity_rate,6),\n     'activity_level_counts':levels,\n     'activity_level_rates':{k:round(v/total_users,6) for k,v in levels.items()},\n  },\n  'users':sorted(users,key=lambda x:x['session_count'],reverse=True),\n  'rankings':{\n     'top3_by_sessions':[{'user_id':u['user_id'],'session_count':u['session_count']} for u in sorted(users,key=lambda x:x['session_count'],reverse=True)[:3]],\n     'top3_by_estimated_total_minutes':[{'user_id':u['user_id'],'estimated_total_minutes':u['estimated_total_minutes']} for u in sorted(users,key=lambda x:x['estimated_total_minutes'],reverse=True)[:3]],\n  },\n  'notes':[\n     'estimated_total_minutes = session_count * avg_duration_min.',\n     'overall_activity_rate is normalized as sessions per user per day over the period.'\n  ]\n}\nreport={\n  'meta':{\n     'created_at':'2026-03-31T09:00:00+08:00',\n     'author':'metaclaw_agent',\n     'status':'done'\n  },\n  'content':content\n}\nout=Path('day12/20260331_user_activity_report.json')\nout.write_text(json.dumps(report,indent=2,ensure_ascii=False)+\"\\n\")\nprint('wrote',out)\nprint('levels',levels,'activity_rate',round(activity_rate,6))\nPY"
