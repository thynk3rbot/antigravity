# RAG Router Configuration
# Copy this to .env and fill in your values

# Dify (RAG Engine)
DIFY_BASE_URL=http://dify-api:5001/v1
DIFY_API_KEY=app-xxxxxxxxxxxxxxxx

# MQTT Broker
MQTT_BROKER=emqx
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=

# RAG Router Server
RAG_ROUTER_PORT=8200
LOG_LEVEL=INFO

# Knowledge Base IDs (one per expert domain)
# Obtain these from Dify UI after uploading documents
KNOWLEDGE_ID_NUTRIENT=dataset-xxxxxxxxxxxxxxxx-nutrient
KNOWLEDGE_ID_BOTANICAL=dataset-xxxxxxxxxxxxxxxx-botanical
KNOWLEDGE_ID_HARDWARE=dataset-xxxxxxxxxxxxxxxx-hardware

# Optional: Add custom knowledge bases
# KNOWLEDGE_ID_CUSTOM_DOMAIN=dataset-xxxxxxxxxxxxxxxx-custom
