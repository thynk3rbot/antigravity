# VIAI RAG Router Configuration
# Copy to .env and fill in your values

# ── Dify RAG Engine ──
# Local dev: http://host.docker.internal:8400/v1
# Production: https://dify.viai.club/v1
DIFY_BASE_URL=http://host.docker.internal:8400/v1
DIFY_API_KEY=dataset-REPLACE_ME

# ── MQTT Broker ──
MQTT_BROKER=emqx
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=

# ── RAG Router ──
RAG_ROUTER_PORT=8403
LOG_LEVEL=INFO

# ── Knowledge Base IDs ──
KNOWLEDGE_ID_USVI=REPLACE_WITH_DATASET_ID
